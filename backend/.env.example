OPENAI_API_KEY=your_openai_api_key_here
# Any OpenAI-compatible endpoint. Empty = api.openai.com.
# Groq free tier: OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   with STT_MODEL=whisper-large-v3-turbo and ANALYZER_MODEL=openai/gpt-oss-120b
OPENAI_BASE_URL=
DATABASE_URL=postgres://meetingmind:developmentpassword@localhost:5432/meetingmind
STT_MODEL=whisper-1
ANALYZER_MODEL=gpt-4o-mini
PORT=8080
MAX_UPLOAD_MB=25
TEMP_DIR=./tmp/audio
